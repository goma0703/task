N = int(input())

for i in range(N):
    s = []
    n = input()
    for j in n:
        if j == '(':
            s.append(j)
        elif j == ')':
            if s:
                s.pop()
            else:
                print("NO")
                break
    else:
        if not s:
            print("YES")
        else:
            print("NO")
